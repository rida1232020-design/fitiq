{
  "name": "fitiq-iraq",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "ajv": "^8.20.0",
    "axios": "^1.6.8",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "react-scripts": "^0.0.0",
    "typescript": "4.9.5"
  },
  "proxy": "http://localhost:5000",
  "scripts": {
    "start": "react-scripts start",
    "server": "node server.js",
    "dev": "concurrently \"npm run start\" \"npm run server\"",
    "build": "react-scripts build",
    "build:android": "react-scripts build && npx cap sync android",
    "build:release": "react-scripts build && npx cap sync android && cd android && gradlew assembleRelease",
    "build:apk": "react-scripts build && npx cap sync android && cd android && gradlew assembleDebug",
    "release:apk": "react-scripts build && npx cap sync android && cd android && gradlew bundleRelease",
    "release:android": "npx cap sync android && cd android && gradlew assembleRelease",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "cap:sync": "npx cap sync"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
